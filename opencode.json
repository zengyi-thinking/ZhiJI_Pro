{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Cherry-EE": {
      "npm": "@ai-sdk/openai",
      "name": "Cherry-EE",
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY_EE}",
        "baseURL": "https://ai.last.ee/v1"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "reasoning": true,
          "options": {
